# ============================================================================
# LineMag — 環境変数設定
# このファイルをコピーして .env.local を作成してください
# ============================================================================

# ── Gemini AI ──
GEMINI_API_KEY=AIza...

# ── LINE Messaging API ──
# セキュリティの観点から、本番環境では必ず環境変数で管理してください。
# ソースコードにハードコードしないでください。
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# ── Vercel Cron 認証 ──
CRON_SECRET=your-cron-secret-here

# ── 管理者通知 (オプション) ──
# エラー発生時にLINE Push通知を受け取る管理者のLINEユーザーID
# LINE Developers Console > Your Bot > Webhook > User ID で確認可能
ADMIN_LINE_USER_ID=your-admin-line-user-id

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── ストレージバックエンド ──
# 'file' (デフォルト) または 'supabase'
STORAGE_BACKEND=file
